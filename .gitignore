# OS-generated files
.DS_Store
Thumbs.db

# Python cache & build artifacts
__pycache__/
.pytest_cache/
*.py[cod]
*.pyo
*.so
*.egg-info/

# Virtual environments
.venv/
venv/
env/

# Node dependencies (vendored TradingView bridge under vendor/tradingview-mcp/)
node_modules/

# Tool configurations
.idea/
.vscode/
.envrc
.mcp.json
# Local-only TradingView CDP SSH tunnel (contains host/login — never committed)
run_tw_proxy.sh
# Per-user Claude Code settings (e.g. MYNOTES_DIR env override) — never committed
.claude/settings.local.json
# Personal trading parameter profile (account size, risk limits) — never committed.
# trading_profile.example.json is the committed template.
trading_profile.json

# Logs & temp
logs/
*.log
*.tmp

# Jupyter
.ipynb_checkpoints/

# Generated reports
reports/
reviews/

# Per-symbol runtime state (e.g. parabolic-short SSR carryover files).
# Kept out of commits so production state never leaks into the repo.
state/

# Personal trading artifacts ($TRADING_DATE_DIR): gate files, screener output,
# trade plans, thesis journal, autopilot logs. Never committed.
trading-data/

# CI artifacts
htmlcov/
.coverage
# .secrets.baseline is tracked — needed by detect-secrets pre-commit hook
.env
/tmp

.claude/skills

claude.sh
