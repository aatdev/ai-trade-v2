# Web UI configuration (all optional — sane defaults are derived automatically).

# Port the Express server listens on (prod single-port mode and dev API).
PORT=4000

# Override the trading-data directory. Mirrors the scheduler's TRADING_DATE_DIR
# env var (note: DATE, not DATA). Absolute path, or relative to the repo root.
# TRADING_DATE_DIR=trading-data

# Override the repository root. By default the server walks up from its own
# location / cwd until it finds scripts/run_trading_schedule.py.
# TRADING_PROJECT_ROOT=/absolute/path/to/claude-trading-skills
