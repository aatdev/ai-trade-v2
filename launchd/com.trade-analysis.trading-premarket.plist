<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!--
  US pre-open (~15:00 CET): quick market-regime re-check + order/trigger reminder.
  The script self-skips on non-trading days, so Mon-Fri firing is fine.

  SETUP: Replace $HOME and $PROJECT_DIR before installing.
    sed "s|\$HOME|$HOME|g; s|\$PROJECT_DIR|$(pwd)|g" \
      launchd/com.trade-analysis.trading-premarket.plist \
      > ~/Library/LaunchAgents/com.trade-analysis.trading-premarket.plist
    launchctl load ~/Library/LaunchAgents/com.trade-analysis.trading-premarket.plist
-->
<dict>
	<key>Label</key>
	<string>com.trade-analysis.trading-premarket</string>

	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>$PROJECT_DIR/scripts/run_trading_schedule.sh</string>
		<string>--slot</string>
		<string>premarket</string>
	</array>

	<key>WorkingDirectory</key>
	<string>$PROJECT_DIR</string>

	<key>StartCalendarInterval</key>
	<dict>
		<key>Hour</key>
		<integer>15</integer>
		<key>Minute</key>
		<integer>0</integer>
	</dict>

	<key>EnvironmentVariables</key>
	<dict>
		<key>PATH</key>
		<string>/opt/homebrew/bin:/opt/homebrew/sbin:$HOME/.local/bin:/usr/local/bin:/usr/bin:/bin</string>
		<key>HOME</key>
		<string>$HOME</string>
	</dict>

	<key>StandardOutPath</key>
	<string>$PROJECT_DIR/logs/launchd_trading_premarket.log</string>

	<key>StandardErrorPath</key>
	<string>$PROJECT_DIR/logs/launchd_trading_premarket_error.log</string>

	<key>RunAtLoad</key>
	<false/>
</dict>
</plist>
